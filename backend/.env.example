# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/review_insight

# Review provider: "mock" or "outscraper"
REVIEW_PROVIDER=mock

# Outscraper API key — required when REVIEW_PROVIDER=outscraper
# Get your key at https://outscraper.com
OUTSCRAPER_API_KEY=

# Max reviews to fetch per Outscraper request (default: 100)
OUTSCRAPER_REVIEWS_LIMIT=100

# Outscraper review ordering (for real-review testing)
# sort: most_relevant | newest | highest_rating | lowest_rating
OUTSCRAPER_SORT=newest
# cutoff: optional Unix timestamp — only reviews newer than this (leave empty = all)
OUTSCRAPER_CUTOFF=
# OUTSCRAPER_SKIP is deprecated (API start=timestamp, not offset). Omit or leave 0; value is ignored.

# OpenAI — leave blank to use mock analysis
OPENAI_API_KEY=

# Google Places — leave blank to extract name from Maps URL
GOOGLE_PLACES_API_KEY=

# Legacy flag — kept for backward compatibility
USE_MOCK_REVIEWS=true

# JWT auth (use 32+ characters to avoid HMAC length warnings)
JWT_SECRET_KEY=change-me-in-production-min-32-chars
JWT_EXPIRE_MINUTES=1440
